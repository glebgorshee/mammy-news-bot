# Скопируйте этот файл в .env и впишите реальные значения.
# .env гитом игнорируется.

# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=123456:ABCDEF_your_bot_token

# Юзернейм канала со собакой или числовой chat_id
TELEGRAM_CHAT_ID=@your_channel_username

# Authorization key из developers.sber.ru/studio (base64 строка)
# Опционально — без него используется Google Translate (хуже качество)
GIGACHAT_CREDENTIALS=
